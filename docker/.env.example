TZ=Asia/Singapore

# InfluxDB 3 Core
INFLUXDB_ORG=homelab
INFLUXDB_DATABASE=home
INFLUXDB_TOKEN=replace-with-admin-token

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-strong-password

# MQTT
MQTT_USER=ha
MQTT_PASSWORD=replace-with-strong-password

# Home Assistant API token (required for AI action bridge)
HA_TOKEN=replace-with-ha-long-lived-token

# AI Action Bridge defaults
ACTION_BRIDGE_ENABLED=true
ACTION_PARSE_WITH_OLLAMA=true
OLLAMA_MODEL=llama3.1:8b
# Optional overrides (if empty, uses OLLAMA_MODEL):
ACTION_PARSE_OLLAMA_MODEL=
SUGGESTION_OLLAMA_MODEL=
SUGGESTION_HTTP_TIMEOUT=120
ACTION_HTTP_TIMEOUT=20
ACTION_PARSE_TIMEOUT=60
ACTION_MODE_DEFAULT=auto
ACTION_RATE_LIMIT_SECONDS=2
ACTION_FLIP_COOLDOWN_SECONDS=3
ACTION_COMMAND_TOPIC=home/ai/command
ACTION_RESULT_TOPIC=home/ai/action_result
ACTION_DEVICE_SUGGESTION_TOPIC=home/ai/device_suggestion
ACTION_MODE_TOPIC=home/ai/mode
ACTION_MODE_SET_TOPIC=home/ai/mode/set
ACTION_DEVICE_DISCOVERY_ENABLED=true
ACTION_DEVICE_DISCOVERY_COOLDOWN_SECONDS=600
ACTION_DEVICE_DISCOVERY_IGNORE_OBJECTID_REGEX=(auto_off_enabled|auto_update_enabled|led|brightness(?:_p_\\d+_\\d+)?|physical_controls_locked(?:_p_\\d+_\\d+)?|indicator(?:_light)?|child_lock|buzzer|beep|display|screen|volume)$
ACTION_DYNAMIC_ALIAS_STORE_PATH=/app/runtime/dynamic_aliases.json
# Optional aliases for non-plug devices (JSON object):
# Example: {"desk lamp":"light.desk_lamp","bedroom fan":"fan.bedroom_fan"}
ACTION_EXTRA_ENTITY_MAP_JSON={}

# Voice bridge (Phase 4 defaults)
VOICE_STT_ENGINE=whisper
VOICE_WHISPER_MODEL=small
VOICE_WHISPER_DEVICE=cpu
VOICE_WHISPER_COMPUTE_TYPE=int8
VOICE_LANGUAGES=en,ms,zh
VOICE_TTS_ENABLED=true
VOICE_PUSH_TO_TALK_TIMEOUT_SECONDS=5
VOICE_RESULT_TIMEOUT_SECONDS=20
